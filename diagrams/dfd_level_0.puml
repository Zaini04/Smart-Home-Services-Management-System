@startuml
skinparam componentStyle rectangle

actor "Resident" as resident
actor "Service Provider" as provider
actor "Admin" as admin

rectangle "Smart Home Services\nManagement System" as system

resident --> system : Job Request, GPS Locations & Chat Messages
system --> resident : Booking Status updates & Provider Profiles

provider --> system : KYC Documents & Quotation Bids
system --> provider : Active Nearby Jobs, Chat & Dispatch details

admin --> system : KYC Approvals & Category Modifications
system --> admin : Platform Analytics & Earnings Reports
@enduml
