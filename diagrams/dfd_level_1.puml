@startuml
skinparam handwritten false
skinparam componentStyle rectangle

actor "Resident" as R
actor "Provider" as P
actor "Admin" as A

database "Users DB" as UDB
database "Bookings DB" as BDB
database "Categories DB" as CDB

rectangle "1.0 User Auth & KYC" as Auth
rectangle "2.0 Job Dispatch" as Job
rectangle "3.0 Live Chat Server" as Chat
rectangle "4.0 Admin Actions" as AdmSys

R -> Auth : Signup / Login Credentials
P -> Auth : Profile Data & CNIC Images
Auth -> UDB : Store/Verify User JWT

A -> AdmSys : Review Providers
AdmSys -> UDB : Update Status (Approved KYC)
AdmSys -> CDB : Manage Service Types

R -> Job : Post Job Request (GPS)
Job -> BDB : Create Booking 
Job -> CDB : Fetch Categories

BDB -> Job : Broadcast New Job
Job -> P : Notify Available Provider

P -> Job : Accept & Quote Price
Job -> R : Push Quote Notification

R -> Chat : Send text / upload media
P -> Chat : Reply
Chat -> BDB : Read / Write Message History
@enduml
