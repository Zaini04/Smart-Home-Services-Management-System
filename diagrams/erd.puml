@startuml
' hide the spot
hide circle
skinparam linetype ortho

entity "User" as user {
  * _id : ObjectId
  --
  name : String
  email : String
  password : String
  role : Enum(resident, provider, admin)
  phone : String
}

entity "ServiceProviderProfile" as providerProfile {
  * _id : ObjectId
  --
  userId : ObjectId <<FK>>
  kycStatus : Enum(pending, approved, rejected)
  cnicFrontImage : String
  cnicBackImage : String
  walletBalance : Decimal
}

entity "ServiceCategory" as category {
  * _id : ObjectId
  --
  name : String
  description : String
  icon : String
}

entity "Booking" as booking {
  * _id : ObjectId
  --
  residentId : ObjectId <<FK>>
  providerId : ObjectId <<FK>>
  categoryId : ObjectId <<FK>>
  status : Enum(pending, accepted, completed)
  scheduledTime : Date
  totalAmount : Decimal
  address : String
  coordinates : Point
}

entity "Message" as message {
  * _id : ObjectId
  --
  bookingId : ObjectId <<FK>>
  senderId : ObjectId <<FK>>
  messageType : String(text/image/video)
  content : String
  isRead : Boolean
}

user ||--o| providerProfile : "profile (if provider)"
user ||--o{ booking : "creates / accepts"
category ||--o{ booking : "categorizes"
booking ||--o{ message : "contains socket chat"
user ||--o{ message : "sends"

@enduml
